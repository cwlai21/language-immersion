{
  "manifest_version": 3,
  "name": "Écoute — Listening Tracker (FR/EN)",
  "version": "1.6.3",
  "description": "Auto-detects French and English YouTube videos, tracks listening time to Supabase, with daily/weekly/monthly dashboards.",

  "permissions": [
    "storage",
    "alarms",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://iusnuavugqjdaljgdcij.supabase.co/*",
    "https://api.themoviedb.org/*",
    "https://gimytv.biz/*",
    "https://gimyai.tw/*",
    "https://*.gimygi.my/*",
    "https://*.gimy.bot/*",
    "https://jx.zg12.xyz/*",
    "https://*.netflix.com/*",
    "https://*.disneyplus.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["page-bridge.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://gimytv.biz/*",
        "https://gimyai.tw/*",
        "https://*.gimygi.my/*",
        "https://*.gimy.bot/*",
        "https://jx.zg12.xyz/*",
        "https://*.netflix.com/*",
        "https://*.disneyplus.com/*"
      ],
      "js": ["series-detect.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ]
}
