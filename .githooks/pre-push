#!/bin/sh
# Same sanity check as pre-commit, run again before push as a safety net
# (e.g. a commit made with --no-verify, or a commit from before the hook
# was installed on this machine). Installed via `git config core.hooksPath .githooks`.
set -e
cd "$(git rev-parse --show-toplevel)"

if ! command -v node >/dev/null 2>&1; then
  echo "pre-push: node not found on PATH, skipping sanity tests" >&2
  exit 0
fi

echo "pre-push: running dashboard sanity tests..."
node --test extension/test/*.test.js
